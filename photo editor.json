<body class="bg-background text-on-surface font-body selection:bg-primary/30 min-h-screen flex flex-col">
<header class="fixed top-0 w-full z-50 bg-[#131313]/40 backdrop-blur-3xl bg-gradient-to-b from-[#1b1b1b] to-transparent shadow-[0_20px_40px_rgba(0,0,0,0.4)]">
<div class="flex justify-between items-center px-6 h-20 w-full">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-primary text-2xl cursor-pointer hover:scale-105 transition-all">menu</span>
<h1 class="text-2xl font-black bg-gradient-to-br from-[#c0c1ff] to-[#8083ff] bg-clip-text text-transparent font-headline tracking-tight">Gurucraftpro</h1>
</div>
<div class="hidden md:flex items-center gap-8">
<a class="text-[#c0c1ff] font-bold tracking-tight hover:scale-105 transition-all" href="#">Photo Editor</a>
<a class="text-[#e2e2e2]/60 hover:text-[#c0c1ff] transition-all" href="#">Graphic Design</a>
<a class="text-[#e2e2e2]/60 hover:text-[#c0c1ff] transition-all" href="#">Pillars</a>
</div>
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-primary cursor-pointer hover:scale-105 transition-all">dark_mode</span>
<button class="hidden md:block bg-gradient-to-br from-primary to-primary-container text-on-primary font-bold px-6 py-2 rounded-xl text-sm shadow-[0_0_15px_rgba(192,193,255,0.3)] hover:scale-105 transition-all">Upgrade Pro</button>
</div>
</div>
</header>
<main class="flex-1 pt-24 pb-32 px-4 md:px-8 max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
<aside class="lg:col-span-3 space-y-6">
<div class="bg-surface-container-low rounded-3xl p-6 shadow-2xl space-y-8">
<div>
<h3 class="text-xs font-bold uppercase tracking-widest text-primary mb-4">Edit Tools</h3>
<div class="grid grid-cols-2 gap-3">
<button class="flex flex-col items-center justify-center p-4 bg-surface-container-highest rounded-2xl hover:bg-primary/10 transition-all group">
<span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary mb-2">crop</span>
<span class="text-[10px] font-medium uppercase tracking-tighter">Crop</span>
</button>
<button class="flex flex-col items-center justify-center p-4 bg-surface-container-highest rounded-2xl hover:bg-primary/10 transition-all group">
<span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary mb-2">flip</span>
<span class="text-[10px] font-medium uppercase tracking-tighter">Flip</span>
</button>
<button class="flex flex-col items-center justify-center p-4 bg-surface-container-highest rounded-2xl hover:bg-primary/10 transition-all group">
<span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary mb-2">crop_square</span>
<span class="text-[10px] font-medium uppercase tracking-tighter">Square</span>
</button>
<button class="flex flex-col items-center justify-center p-4 bg-surface-container-highest rounded-2xl hover:bg-primary/10 transition-all group">
<span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary mb-2">background_replace</span>
<span class="text-[10px] font-medium uppercase tracking-tighter">BG Change</span>
</button>
</div>
</div>
<div>
<h3 class="text-xs font-bold uppercase tracking-widest text-primary mb-4">Resizing</h3>
<div class="space-y-4">
<div class="flex items-center justify-between text-sm bg-surface-container-highest/50 p-3 rounded-xl">
<span class="text-on-surface-variant">Width</span>
<input class="w-16 bg-transparent border-none text-right font-bold focus:ring-0" type="text" value="1920"/>
</div>
<div class="flex items-center justify-between text-sm bg-surface-container-highest/50 p-3 rounded-xl">
<span class="text-on-surface-variant">Height</span>
<input class="w-16 bg-transparent border-none text-right font-bold focus:ring-0" type="text" value="1080"/>
</div>
</div>
</div>
<div>
<h3 class="text-xs font-bold uppercase tracking-widest text-primary mb-4">Conversion</h3>
<div class="space-y-2">
<button class="w-full text-left px-4 py-3 rounded-xl bg-surface-container-highest/30 hover:bg-surface-container-highest text-sm flex items-center justify-between group transition-all">
<span>JPG to PDF</span>
<span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-all">arrow_forward</span>
</button>
<button class="w-full text-left px-4 py-3 rounded-xl bg-surface-container-highest/30 hover:bg-surface-container-highest text-sm flex items-center justify-between group transition-all">
<span>PDF to JPG</span>
<span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-all">arrow_forward</span>
</button>
<button class="w-full text-left px-4 py-3 rounded-xl bg-surface-container-highest/30 hover:bg-surface-container-highest text-sm flex items-center justify-between group transition-all">
<span>PNG to WebP</span>
<span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-all">arrow_forward</span>
</button>
</div>
</div>
</div>
</aside>
<section class="lg:col-span-9 space-y-8">
