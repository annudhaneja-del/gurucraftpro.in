</div>
<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20 w-10 h-10 bg-primary rounded-full flex items-center justify-center shadow-lg pointer-events-none">
<span class="material-symbols-outlined text-on-primary">unfold_more</span>
</div>
<div class="absolute bottom-6 left-6 z-30 bg-black/40 backdrop-blur-md px-4 py-1.5 rounded-full text-[10px] uppercase tracking-widest font-bold">Original</div>
<div class="absolute bottom-6 right-6 z-30 bg-primary/40 backdrop-blur-md px-4 py-1.5 rounded-full text-[10px] uppercase tracking-widest font-bold text-on-primary-container">Enhanced</div>
</div>
</div>
</div>
<div class="bg-surface-container rounded-3xl p-8 border border-outline-variant/5">
<div class="flex flex-col md:flex-row items-center justify-between gap-6">
<div class="flex-1 w-full">
<div class="relative group h-32 md:h-24 border-2 border-dashed border-outline-variant/30 rounded-2xl flex items-center justify-center hover:border-primary/50 transition-all cursor-pointer">
<div class="flex items-center gap-4 px-6">
<div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
<span class="material-symbols-outlined">cloud_upload</span>
</div>
<div>
<p class="font-bold text-on-surface">Drop new file here</p>
<p class="text-xs text-on-surface-variant">Supports JPG, PNG, WEBP, PDF (Max 25MB)</p>
</div>
</div>
</div>
</div>
<div class="flex gap-4 w-full md:w-auto">
<button class="flex-1 md:flex-none flex items-center justify-center gap-2 bg-gradient-to-br from-primary to-primary-container text-on-primary font-bold px-8 py-4 rounded-2xl shadow-xl hover:scale-105 active:scale-95 transition-all">
<span class="material-symbols-outlined">download</span>
              Download
            </button>
<button class="flex items-center justify-center w-14 h-14 bg-surface-container-highest rounded-2xl hover:text-primary transition-all">
<span class="material-symbols-outlined">share</span>
</button>
</div>
</div>
<div class="mt-8 flex flex-wrap gap-3">
<span class="text-xs font-bold uppercase tracking-widest text-on-surface-variant w-full mb-2">Share to:</span>
<button class="px-4 py-2 bg-surface-container-highest/40 rounded-full text-xs hover:bg-primary/20 transition-all">Instagram</button>
<button class="px-4 py-2 bg-surface-container-highest/40 rounded-full text-xs hover:bg-primary/20 transition-all">Behance</button>
<button class="px-4 py-2 bg-surface-container-highest/40 rounded-full text-xs hover:bg-primary/20 transition-all">Pinterest</button>
<button class="px-4 py-2 bg-surface-container-highest/40 rounded-full text-xs hover:bg-primary/20 transition-all">X (Twitter)</button>
</div>
</div>
</section>
