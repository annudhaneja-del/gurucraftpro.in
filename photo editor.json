<nav class="fixed bottom-0 w-full rounded-t-[2rem] z-50 bg-[#1b1b1b]/40 backdrop-blur-2xl border-t border-[#464554]/15 shadow-[0_-10px_30px_rgba(0,0,0,0.5)] md:hidden">
<div class="flex justify-around items-center h-20 px-8 pb-safe">
<div class="flex flex-col items-center justify-center text-[#e2e2e2]/50 w-12 h-12 hover:text-[#c0c1ff] transition-colors">
<span class="material-symbols-outlined">home</span>
</div>
<div class="flex flex-col items-center justify-center bg-gradient-to-br from-[#c0c1ff] to-[#8083ff] text-[#131313] rounded-full w-12 h-12 shadow-[0_0_15px_rgba(192,193,255,0.3)] animate-pulse-subtle scale-110">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">grid_view</span>
</div>
<div class="flex flex-col items-center justify-center text-[#e2e2e2]/50 w-12 h-12 hover:text-[#c0c1ff] transition-colors">
<span class="material-symbols-outlined">person</span>
</div>
</div>
</nav>
</body></html>
